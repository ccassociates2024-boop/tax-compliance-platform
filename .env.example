# ─── App ─────────────────────────────────────────────────────────────────────
DEBUG=false
SECRET_KEY=your-256-bit-secret-key-here-change-in-production
APP_NAME=TaxCompliance AI Platform

# ─── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=strongpassword123
DATABASE_URL=postgresql+asyncpg://taxadmin:strongpassword123@db:5432/taxcompliance

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redispassword
REDIS_URL=redis://:redispassword@redis:6379/0

# ─── Credential Vault (AES-256) ───────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_KEY=your-64-hex-char-aes-256-key-here
VAULT_SALT=your-unique-per-deployment-salt-here

# ─── AI — Google Gemini (free tier: https://aistudio.google.com/apikey) ──────
GEMINI_API_KEY=AIza...
AI_MODEL=gemini-2.0-flash

# ─── AWS (Mumbai region for Indian data residency) ────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=ap-south-1
S3_BUCKET_DOCUMENTS=taxcompliance-docs-india

# ─── Celery ──────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redispassword@redis:6379/1
CELERY_RESULT_BACKEND=redis://:redispassword@redis:6379/2

# ─── Razorpay (get from dashboard.razorpay.com) ───────────────────────────────
# Test keys: rzp_test_...  |  Live keys: rzp_live_...
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret
