# ─────────────────────────────────────────────────────────────────────────────
# TaxCompliance AI — DEMO MODE environment
# Run: docker compose -f docker-compose.demo.yml up --build
# ─────────────────────────────────────────────────────────────────────────────

# Enable demo mode
DEMO_MODE=true
DEMO_USER_EMAIL=demo@taxcomplianceai.in
DEMO_USER_PASSWORD=demo123

# App secrets — use any random values for demo (not production!)
SECRET_KEY=demo-secret-key-change-this-in-production-32chars!!
VAULT_MASTER_KEY=demo-vault-key-change-this-in-production-32ch!
VAULT_SALT=taxcompliance-demo-salt-2025

# Database — internal Docker network
DATABASE_URL=postgresql+asyncpg://taxuser:demo_db_pass@db:5432/taxdb
DB_PASSWORD=demo_db_pass

# Redis — internal Docker network
REDIS_URL=redis://:demo_redis_pass@redis:6379/0
REDIS_PASSWORD=demo_redis_pass
CELERY_BROKER_URL=redis://:demo_redis_pass@redis:6379/1
CELERY_RESULT_BACKEND=redis://:demo_redis_pass@redis:6379/2

# AI — leave blank in demo (canned responses are used instead)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# AWS — leave blank in demo
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_DOCUMENTS=taxcompliance-docs-demo

# Razorpay — leave blank in demo (payment simulation is used instead)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Debug (enable swagger UI in demo)
DEBUG=true
